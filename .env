# Application position inside the container
APP_PATH=/remote_fs_app

# Client
MOUNT_POINT=/mnt/remote-fs
SERVER_URL=http://localhost:8080 # for local testing with server on localhost

# Server
SERVER_HOST=localhost # for local testing with server on localhost
#SERVER_HOST=server
SERVER_PORT=8080
FS_ROOT=/remote_fs
DISPLAY=:0


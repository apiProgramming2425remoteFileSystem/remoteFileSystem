import {
    Button,
    VerticalBox,
    LineEdit,
    Spinner,
    ScrollView,
    HorizontalBox,
    Palette,
} from "std-widgets.slint";

global FontPalette {
    in-out property <int> scale: 1;
    // Dimensioni standard
    in-out property <length> font-small: 12px * scale;
    in-out property <length> font-normal: 14px * scale;
    in-out property <length> font-medium: 18px * scale;
    in-out property <length> font-large: 20px * scale;
    in-out property <length> font-title: 24px * scale;

    // Famiglie standard (opzionale)
    in-out property <string> font-family-default: "sans-serif";
    in-out property <string> font-familiy-code: "monospace";
}

export enum ViewState {
    Welcome,
    Home,
    Cache,
    MountPoint,
}

export enum Status {
    LoggedIn,
    NotLoggedIn,
}

export struct MountSettings {
    mount_point: string,
    allow_other: bool,
    read_only: bool,
    privileged: bool,
}

export struct CacheSettings {
    enabled: bool,
    use_ttl: bool,
    ttl: int,
    policy: string,
    max_size: int,
    capacity: int,
}

export struct FsSettings {
    foreground: bool,
    xattr_enable: bool,
    page_size: int,
    max_pages: int,
    buffer_size: int,
}

export struct LogSettings {
    format: string,
    level: string,
    dir: string,
    file: string,
    rotation: string,
}

export struct BoolItem {
    env: string,
    name: string, 
    value: bool, 
    id_rust: string,
}

export struct IntItem {
    env: string,
    name: string, 
    value: int, 
    id_rust: string,
}

export struct StringItem {
    env: string,
    name: string, 
    value: string, 
    id_rust: string,
}

export struct ListItem {
    name: string, 
    id_rust: string,
}

/* UTILS */
export component MyButton inherits Rectangle {
    in property <string> text;
    in property <brush> text_color;
    in property <brush> button_color;
    in property <length> button_width;
    in property <length> button_height;
    in property <bool> is_active;
    callback on_click;
    height: button_height;
    width: button_width;
    border-radius: 8px;
    animate background { duration: 150ms; }
    ta := TouchArea {
        enabled: root.is_active;
        clicked => {
            root.on_click();
        }
    }

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 8px;
        background: ta.pressed ? button_color.transparentize(0.1) : ta.has-hover ? button_color.transparentize(0.2) : button_color;
        Text {
            vertical-alignment: center;
            text: root.text;
            color: text_color;
            font-weight: 500;
        }
    }
}

export component Error inherits Rectangle {
    in property <string> error;
    callback close;
    background: #fffdfd37;
    TouchArea {
        clicked => {
            root.close();
        }
    }

    Rectangle {
        width: 30%;
        height: 20%;
        border-radius: 8px;
        background: #FF4E3B;
        Text {
            width: 100%;
            height: 100%;
            font-size: FontPalette.font-medium;
            vertical-alignment: center;
            horizontal-alignment: center;
            text: error;
            color: white;
            wrap: TextWrap.word-wrap;
        }
    }
}

export component Loading inherits Rectangle {
    Rectangle {
        width: 100%;
        height: 100%;
        background: white;
        opacity: 60%;
        TouchArea { }
    }

    VerticalLayout {
        alignment: center;
        spacing: 20px;
        Text {
            vertical-alignment: center;
            horizontal-alignment: center;
            color: black;
            font-size: FontPalette.font-large;
            font-weight: 600;
            text: "Loading...";
        }
    }
}

export component IntEdit inherits Rectangle {
    in property <bool> fs_is_active;
    in property <string> name;
    in property <string> value;
    in property <brush> text_color;
    in property <length> toggle_width;
    in property <length> toggle_height;
    in property <brush> toggle_color;
    in-out property <bool> is_edit_view: false;
    in-out property <string> new_value_string;
    in-out property <int> new_value;
    in-out property <string> guide;
    callback on_click(int);
    width: root.toggle_width;
    height: is_edit_view ? root.toggle_height * 1.8 : root.toggle_height;
    border-radius: 8px;
    ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: !fs_is_active;
        clicked => {
            root.is_edit_view = true;
        }
    }

    background: ta.pressed ? toggle_color.transparentize(0.1) : ta.has-hover ? toggle_color.transparentize(0.2) : toggle_color;
    HorizontalLayout {
        alignment: center;
        VerticalLayout {
            alignment: center;
            spacing: 2px;

            /* NAME */
            HorizontalLayout {
                alignment: center;
                Text {
                    vertical-alignment: center;
                    text: root.name;
                    color: text_color;
                    font-weight: 500;
                }
            }
            
            /* VALUE */
            if (!is_edit_view):
                HorizontalLayout {
                alignment: center;
                Text {
                    vertical-alignment: center;
                    text: root.value;
                    color: text_color;
                    font-weight: 600;
                }
            }
            if (is_edit_view):
                HorizontalLayout {
                height: 40%;
                width: 100%;
                alignment: center;
                spacing: 2px;
                LineEdit {
                    width: root.toggle_width * 0.5;
                    height: 30%;
                    placeholder-text: guide;
                    input-type: InputType.decimal;
                    text <=> root.new_value_string;
                }

                MyButton {
                    is_active: true;
                    width: root.toggle_width * 0.3;
                    height: 20%;
                    text: root.new_value_string != "" ? "OK" : "X";
                    text_color: white;
                    background: root.new_value_string != "" ? #34C759 : #FF383C;
                    on_click => {
                        root.is_edit_view = false;
                        if (root.new_value_string != "") {
                            root.on_click(root.new_value_string.to-float());
                        }
                    }
                }
            }
        }
    }
}

export component StringEdit inherits Rectangle {
    in property <bool> fs_is_active;
    in property <string> name;
    in property <string> value;
    in property <brush> text_color;
    in-out property <string> guide;
    in property <length> toggle_width;
    in property <length> toggle_height;
    in property <brush> toggle_color;
    in-out property <bool> is_edit_view: false;
    in-out property <string> new_value;
    callback on_click(string);
    width: root.toggle_width;
    height: is_edit_view ? root.toggle_height * 1.5 : root.toggle_height;
    border-radius: 8px;
    ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: !fs_is_active;
        clicked => {
            root.is_edit_view = true;
        }
    }

    background: ta.pressed ? toggle_color.transparentize(0.1) : ta.has-hover ? toggle_color.transparentize(0.2) : toggle_color;
    VerticalLayout {
        alignment: center;
        spacing: 2px;

        /* NAME */
        HorizontalLayout {
            alignment: center;
            Text {
                vertical-alignment: center;
                text: root.name;
                color: text_color;
                font-weight: 500;
            }
        }

        /* VALUE */
        if (!is_edit_view):
            HorizontalLayout {
            alignment: center;
            Text {
                vertical-alignment: center;
                text: root.value;
                color: text_color;
                font-weight: 600;
            }
        }
        if (is_edit_view):
            HorizontalLayout {
            alignment: center;
            spacing: 2px;
            LineEdit {
                width: root.toggle_width * 0.5;
                height: 40%;
                placeholder-text: guide != "" ? guide : "change it";
                font-size: FontPalette.font-small;
                input-type: InputType.text;
                text <=> root.new_value;
            }

            MyButton {
                is_active: true;
                width: root.toggle_width * 0.3;
                height: 40%;
                text: root.new_value != "" ? "OK" : "X";
                text_color: white;
                background: root.new_value != "" ? #34C759 : #FF383C;
                on_click => {
                    root.is_edit_view = false;
                    if (root.new_value != "") {
                        root.on_click(root.new_value);
                    }
                }
            }
        }
    }
}

export component DropDown inherits Rectangle {
    in property <bool> fs_is_active;
    in property <brush> text_color;
    in property <length> toggle_width;
    in property <length> toggle_height;
    in property <brush> toggle_color;
    in property <string> name;
    in property <[string]> options: ["Opzione 1", "Opzione 2", "Opzione 3"];
    in property <string> selected_value: "Opzione 1";
    callback on_click(string);
    private property <bool> is_open: false;
    width: toggle_width;
    height: toggle_height;
    border-radius: 8px;
    background: ta.pressed ? toggle_color.transparentize(0.1) : ta.has-hover ? toggle_color.transparentize(0.2) : toggle_color;
    ta := TouchArea {
        enabled: !fs_is_active;
        clicked => {
            if is_open {
                popup.close();
                is_open = false;
            } else {
                popup.show();
                is_open = true;
            }
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 2px;

        /* HEADER */
        HorizontalLayout {
            alignment: center;
            Text {
                vertical-alignment: center;
                text: root.name;
                color: text_color;
                font-weight: 500;
            }
        }

        /* VALUE */
        HorizontalLayout {
            alignment: center;
            Text {
                text: selected_value;
                y: parent.height / 2 - self.height / 2;
                color: text_color;
                font-weight: 600;
            }
        }
    }

    /* POPUP */
    popup := PopupWindow {
        close_policy: PopupClosePolicy.close-on-click;
        x: 0.3 * root.width;
        y: root.y + root.height;
        Rectangle {
            width: 100px;
            border-width: 5px;
            border-radius: 8px;
            background: white;
            VerticalLayout {
                spacing: 10px;
                for option[i] in options: Rectangle {
                    height: 30px;
                    MyButton {
                        text: option;
                        text_color: option != selected_value ? black : white;
                        button_width: 100px;
                        button_height: 30px;
                        button_color: option != selected_value ? #ECF0F1 : #a1a4a5;
                        is_active: option != selected_value;
                        on_click => {
                            root.on_click(option);
                        }
                    }
                }
            }
        }
    }
}

/* WELCOME PAGE */
export component WelcomePage inherits VerticalBox {
    padding: 20px;
    spacing: 10px;
    Text {
        text: "Welcome to RemoteFileSystem!";

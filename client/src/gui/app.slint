}

/* LOGIN MANAGEMENT */
export component LoginForm inherits Rectangle {
    in-out property <string> username;
    in-out property <string> password;
    callback login(string, string);
    VerticalLayout {
        spacing: 20px;
        padding: 40px;
        alignment: center;
        Rectangle {
            background: rgb(0, 128, 255, 0.8);
            border-radius: 8px;
            drop-shadow-blur: 15px;
            drop-shadow-color: #ffffff3b;
            width: 50%;
            height: 60%;
            layout := VerticalBox {
                padding: 20px;
                spacing: 15px;
                Text {
                    text: "LOGIN";
                    font-size: FontPalette.font-medium;
                    font-weight: 800;
                    horizontal-alignment: center;
                    color: white;
                }

                // Campo Username
                VerticalBox {
                    padding: 0;
                    spacing: 10px;
                    Text {
                        text: "Username";
                        color: white;
                        font-size: FontPalette.font-normal;
                    }

                    u := LineEdit {
                        placeholder-text: "username";
                        input-type: InputType.text;
                        text <=> root.username;
                    }
                }

                // Campo Password
                VerticalBox {
                    padding: 0;
                    spacing: 10px;
                    Text {
                        text: "Password";
                        color: white;
                        font-size: FontPalette.font-normal;
                    }

                    p := LineEdit {
                        placeholder-text: "••••••••";
                        input-type: InputType.password;
                        text <=> root.password;
                    }
                }

                // Spazio vuoto tattico
                Rectangle {
                    height: 10px;
                }

                // Pulsante di Login
                Button {
                    text: "Login";
                    primary: true;
                    // Disabilita se i campi sono vuoti
                    enabled: root.username != "" && root.password != "";
                    clicked => {
                        root.login(root.username, root.password);
                        u.text = "";
                        p.text = "";
                    }
                }
            }
        }
    }
}

/* DASHBOARD CONTENT */
export global Round {
    public pure function format_MB(bytes: int) -> float {
        return Math.round(bytes / (1024 * 1024) * 100) / 100;
    }
}

export component Fs inherits Rectangle {
    in property <bool> fs_is_active;
    in property <MountSettings> mount_settings;
    in property <FsSettings> fs_settings;
    callback change_bool_property(BoolItem);
    callback change_string_property(StringItem);
    in-out property <bool> is_more_view: false;
    in property <[ListItem]> bool_items: [
        { name: "Allow Other", id_rust: "allow_other" },
        { name: "Read Only", id_rust: "read_only" },
        { name: "Privileged", id_rust: "privileged" },
    ];
    background: white;
    height: 60%;
    width: 25%;
    border-radius: 8px;
    VerticalLayout {
        alignment: start;
        
        /* HEADER */
        Rectangle {
            background: rgba(0, 128, 255, 0.5);
            border-radius: 8px;
            width: 100%;
            height: 20%;
            Text {
                color: black;
                font-weight: 600;
                horizontal-alignment: center;
                text: "FS MANAGEMENT";
            }
        }

        /* DEFAULT VIEW */
        if !root.is_more_view:
            ScrollView {
            width: 100%;
            height: 80%;
            VerticalLayout {
                padding: 5px;
                spacing: 10px;
                alignment: center;

                /* mountpoint */
                HorizontalLayout {
                    alignment: center;
                    StringEdit {
                        toggle_width: 170px;
                        toggle_height: 50px;
                        fs_is_active: fs_is_active;
                        name: "MOUNTPOINT";
                        value: root.mount_settings.mount-point != "" ? root.mount_settings.mount-point : "click to choose";
                        text_color: black;
                        toggle_color: #ECF0F1;
                        on_click(v) => {
                            root.change_string_property({ env: "MOUNT", name: "", value: v, id_rust: "mountpoint" });
                        }
                    }
                }

                /* xattr_enable */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    MyButton {
                        button_width: 100px;
                        button_height: 40px;
                        button_color: root.fs_settings.xattr-enable ? #FF383C : #34C759;
                        is_active: !root.fs_is_active;
                        text_color: white;
                        text: root.fs_settings.xattr-enable ? "DISABLE XATTR" : "ENABLE XATTR";
                        on_click => {
                            root.change_bool_property({ env: "FS", name: "", value: !root.fs_settings.xattr-enable, id_rust: "xattr_enable" });
                        }
                    }
                }

                /* buffer_size */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    IntEdit {
                        toggle_width: 100px;
                        toggle_height: 40px;
                        fs_is_active: fs_is_active;
                        name: "BUFFER SIZE";
                        value: Round.format_MB(root.fs_settings.buffer-size) + " MB";
                        guide: "12.3";
                        text_color: black;
                        toggle_color: #ECF0F1;
                        on_click(n) => {
                            root.change_string_property({ env: "FS", name: "", value: n * 1024 * 1024, id_rust: "buffer_size" });
                        }
                    }
                }

                /* MORE BUTTON */
                HorizontalLayout {
                    alignment: center;
                    MyButton {
                        button_width: 100px;
                        button_height: 40px;
                        button_color: #ECF0F1;
                        text_color: black;
                        text: "MORE";
                        is_active: true;
                        on_click => {
                            root.is_more_view = true;
                        }
                    }
                }
            }
        }
               
        /* MORE VIEW */
        if root.is_more_view:
            VerticalLayout {
            alignment: center;
            width: 100%;
            height: 80%;
            spacing: 10px;
            for item in bool_items: HorizontalLayout {
                width: 100%;
                alignment: center;
                MyButton {
                    button_width: 100px;
                    button_height: 40px;
                    button_color: root.get_value(item.id_rust) ? #34C759 : #FF383C;
                    is_active: !root.fs_is_active;
                    text_color: white;
                    text: item.name;
                    on_click => {
                        root.change_bool_property({
                            env: "MOUNT",
                            name: item.name,
                            value: !root.get_value(item.id_rust),
                            id_rust: item.id_rust
                        });
                    }
                }
            }

            /* BACK BUTTON */
            HorizontalLayout {
                width: 100%;
                alignment: center;
                MyButton {
                    button_width: 100px;
                    button_height: 40px;
                    button_color: #ECF0F1;
                    text_color: black;
                    text: "BACK";
                    is_active: true;
                    on_click => {
                        root.is_more_view = false;
                    }
                }
            }
        }
    }

    pure function get_value(id: string) -> bool {
        if (id == "allow_other") {
            return mount_settings.allow_other;
        }
        if (id == "read_only") {
            return mount_settings.read_only;
        }
        if (id == "privileged") {
            return mount_settings.privileged;
        }
        return false;
    }
}

export component Cache inherits Rectangle {
    in property <bool> fs_is_active;
    in property <CacheSettings> cache_settings;
    callback change_bool_property(BoolItem);
    callback change_int_property(IntItem);
    callback change_string_property(StringItem);
    background: white;
    height: 60%;
    width: 25%;
    border-radius: 8px;
    VerticalLayout {
        alignment: start;

        /* HEADER */
        Rectangle {
            background: rgba(0, 128, 255, 0.5);
            border-radius: 8px;
            width: 100%;
            height: 20%;
            Text {
                color: black;
                font-weight: 600;
                horizontal-alignment: center;
                text: "CACHE MANAGEMENT";
            }
        }

        /* BUTTONS */
        ScrollView {
            width: 100%;
            height: 80%;
            VerticalLayout {
                padding: 5px;
                spacing: 10px;
                alignment: center;

                /* enable_cache */
                HorizontalLayout {
                    alignment: center;
                    MyButton {
                        button_width: 150px;
                        button_height: 40px;
                        button_color: root.cache_settings.enabled ? #FF383C : #34C759;
                        is_active: !root.fs_is_active;
                        text_color: white;
                        text: root.cache_settings.enabled ? "DISABLE CACHE" : "ENABLE CACHE";
                        on_click => {
                            root.change_bool_property({ env: "CACHE", name: "", value: !root.cache_settings.enabled, id_rust: "cache_enabled" });
                        }
                    }
                }

                if root.cache_settings.enabled: 
                    VerticalLayout {
                    alignment: center;
                    spacing: 10px;
                        
                    /* policy */
                    HorizontalLayout {
                        alignment: center;
                        DropDown {
                            fs_is_active: fs_is_active;
                            name: "CACHE POLICY";
                            toggle_width: 150px;
                            toggle_height: 50px;
                            text_color: black;
                            toggle_color: #ECF0F1;
                            options: ["LRU", "LFU"];
                            selected_value: root.cache_settings.policy;
                            on_click(v) => {
                                root.change_string_property({ env: "CACHE", name: "", value: v, id_rust: "policy" });
                            }
                        }
                    }

                    /* use_ttl */
                    HorizontalLayout {
                        alignment: center;
                        MyButton {
                            button_width: 120px;
                            button_height: 40px;
                            button_color: root.cache_settings.use_ttl ? #FF383C : #34C759;
                            is_active: !root.fs_is_active;
                            text_color: white;
                            text: root.cache_settings.use_ttl ? "DISABLE TTL" : "USE TTL";
                            on_click => {
                                root.change_bool_property({ env: "CACHE", name: "", value: !root.cache_settings.use_ttl, id_rust: "use_ttl" });
                            }
                        }
                    }
                        
                    /* ttl */
                    if (root.cache_settings.use_ttl):
                        HorizontalLayout {
                        alignment: center;
                        IntEdit {
                            toggle_width: 120px;
                            toggle_height: 40px;
                            fs_is_active: fs_is_active;
                            name: "TTL";
                            value: root.cache_settings.ttl + " s";
                            guide: "123";
                            text_color: black;
                            toggle_color: #ECF0F1;
                            on_click(n) => {
                                root.change_int_property({ env: "CACHE", name: "", value: n, id_rust: "ttl" });
                            }
                        }
                    }
                            
                    /* cache_max_size */
                    HorizontalLayout {
                        alignment: center;
                        IntEdit {
                            toggle_width: 120px;
                            toggle_height: 40px;
                            fs_is_active: fs_is_active;
                            name: "CACHE MAX SIZE";
                            value: Round.format_MB(root.cache_settings.max-size) + " MB";
                            guide: "12.3";
                            text_color: black;
                            toggle_color: #ECF0F1;
                            on_click(n) => {
                                root.change_int_property({ env: "CACHE", name: "", value: n * 1024 * 1024, id_rust: "max_size" });
                            }
                        }
                    }
                        
                    /* cache_capacity */
                    HorizontalLayout {
                        alignment: center;
                        IntEdit {
                            toggle_width: 120px;
                            toggle_height: 40px;
                            fs_is_active: fs_is_active;
                            name: "CACHE CAPACITY";
                            value: root.cache_settings.capacity + " entries";
                            guide: "123";
                            text_color: black;
                            toggle_color: #ECF0F1;
                            on_click(n) => {
                                root.change_int_property({ env: "CACHE", name: "", value: n, id_rust: "capacity" });
                            }
                        }
                    }
                }
            }
        }
    }
}

export component Log inherits Rectangle {
    in property <bool> fs_is_active;
    in property <LogSettings> log_settings;
    callback change_bool_property(BoolItem);
    callback change_int_property(IntItem);
    callback change_string_property(StringItem);
    background: white;
    height: 60%;
    width: 25%;
    border-radius: 8px;
    VerticalLayout {
        alignment: start;

        // Header
        Rectangle {
            background: rgba(0, 128, 255, 0.5);
            border-radius: 8px;
            width: 100%;
            height: 20%;
            Text {
                color: black;
                font-weight: 600;
                horizontal-alignment: center;
                text: "LOG MANAGEMENT";
            }
        }

        // LOGGING SETTINGS
        ScrollView {
            width: 100%;
            height: 80%;
            VerticalLayout {
                alignment: center;
                padding: 5px;
                spacing: 10px; 

                /* log_dir */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    StringEdit {
                        toggle_width: 170px;
                        toggle_height: 50px;
                        fs_is_active: fs_is_active;
                        name: "LOG DIRECTORY";
                        value: root.log_settings.dir == "" ? "click to choose" : root.log_settings.dir;
                        text_color: black;
                        toggle_color: #ECF0F1;
                        on_click(v) => {
                            root.change_string_property({ env: "LOG", name: "", value: v, id_rust: "log_dir" });
                        }
                    }
                }

                /* log_file */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    StringEdit {
                        toggle_width: 170px;
                        toggle_height: 50px;
                        fs_is_active: fs_is_active;
                        name: "LOG FILE";
                        value: root.log_settings.file == "" ? "click to choose" : root.log_settings.file;
                        text_color: black;
                        toggle_color: #ECF0F1;
                        on_click(v) => {
                            root.change_string_property({ env: "LOG", name: "", value: v, id_rust: "log_file" });
                        }
                    }
                }

                /* log_format */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    DropDown {
                        fs_is_active: fs_is_active;
                        name: "LOG FORMAT";
                        toggle_width: 150px;
                        toggle_height: 50px;
                        text_color: black;
                        toggle_color: #ECF0F1;
                        options: ["COMPACT", "FULL", "JSON", "PRETTY"];
                        selected_value: root.log_settings.format;
                        on_click(v) => {
                            root.change_string_property({ env: "LOG", name: "", value: v, id_rust: "log_format" });
                        }
                    }
                }

                /* log_level */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    DropDown {
                        fs_is_active: fs_is_active;
                        name: "LOG LEVEL";
                        toggle_width: 150px;
                        toggle_height: 50px;
                        text_color: black;
                        toggle_color: #ECF0F1;
                        options: ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"];
                        selected_value: root.log_settings.level;
                        on_click(v) => {
                            root.change_string_property({ env: "LOG", name: "", value: v, id_rust: "log_level" });
                        }
                    }
                }

                /* log_rotation */
                HorizontalLayout {
                    width: 100%;
                    alignment: center;
                    DropDown {
                        fs_is_active: fs_is_active;
                        name: "LOG ROTATION";
                        toggle_width: 150px;
                        toggle_height: 50px;
                        text_color: black;
                        toggle_color: #ECF0F1;
                        options: ["MINUTELY", "HOURLY", "DAILY", "NEVER"];
                        selected_value: root.log_settings.rotation;
                        on_click(v) => {
                            root.change_string_property({ env: "LOG", name: "", value: v, id_rust: "log_rotation" });
                        }
                    }
                }
            }
        }
    }
}


/* HOME */
export component Home inherits Rectangle {
    in property <Status> status;
    in property <bool> fs_is_active;
    callback login(string, string);
    callback logout();
    callback mount();
    callback unmount();
    callback select_mountpoint();
    callback change_bool_property(BoolItem);
    callback change_int_property(IntItem);
    callback change_string_property(StringItem);
    callback restore_default();
    in property <MountSettings> mount_settings;
    in property <CacheSettings> cache_settings;
    in property <FsSettings> fs_settings;
    in property <LogSettings> log_settings;
    in property <bool> show_restore_default;
    height: 100%;
    width: 100%;
    VerticalBox {
        padding: 0;
        spacing: 0;

        /* --- HEADER --- */
        Rectangle {
            height: 10%;
            background: #0080FF;
            HorizontalLayout {
                padding: 15px;
                height: 100%;
                alignment: LayoutAlignment.end;
            
                // Titolo centrale
                Rectangle {
                    width: 33%;
                    Text {
                        text: "Remote FS";
                        color: white;
                        font-size: FontPalette.font-medium;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                } 
                
                // Bottone a destra
                HorizontalLayout {
                    width: 33%;
                    alignment: LayoutAlignment.end;
                    padding-right: 80px;
                    if (status == Status.LoggedIn):
                        VerticalLayout {
                        alignment: center;
                        MyButton {
                            text: "LOGOUT";
                            text_color: white;
                            button_color: #ff383bd4;
                            button_width: 100px;
                            button_height: 40px;
                            is_active: true;
                            on_click => {
                                root.logout();
                            }
                        }
                    }
                }
            }
        }

        /* --- CONTENT --- */
        Rectangle {
            background: #ecf0f1;
            height: 80%; 

            /* NO LOGIN */
            HorizontalLayout {
                visible: status == Status.NotLoggedIn;
                opacity: status == Status.NotLoggedIn ? 1 : 0;
                animate opacity {
                    duration: 500ms;
                    easing: ease-in-out;
                }
                alignment: center;
                LoginForm {
                    login(u, p) => {
                        root.login(u, p);
                    }
                }
            }

            /* MANAGEMENT DASHBOARD */
            VerticalLayout {
                visible: status == Status.LoggedIn;
                opacity: status == Status.LoggedIn ? 1 : 0;
                animate opacity {
                    duration: 500ms;
                    easing: ease-in-out;
                }
                alignment: center;
                spacing: 20px;
                HorizontalLayout {
                    spacing: 40px;
                    alignment: center;
                    Fs {
                        fs_is_active: fs_is_active;
                        mount_settings: root.mount_settings;
                        fs_settings: root.fs_settings;
                        change_string_property(s) => {
                            root.change_string_property(s);
                        }
                        change_bool_property(b) => {
                            root.change_bool_property(b);
                        }
                    }

                    Cache {
                        fs_is_active: root.fs_is_active;
                        cache_settings: root.cache_settings;
                        change_bool_property(b) => {
                            root.change_bool_property(b);
                        }
                        change_int_property(i) => {
                            root.change_int_property(i);
                        }
                        change_string_property(s) => {
                            root.change_string_property(s);
                        }
                    }

                    Log {
                        fs_is_active: root.fs_is_active;
                        log_settings: root.log_settings;
                        change_bool_property(b) => {
                            root.change_bool_property(b);
                        }
                        change_int_property(i) => {
                            root.change_int_property(i);
                        }
                        change_string_property(s) => {
                            root.change_string_property(s);
                        }
                    }
                }

                /* CENTRAL BUTTON */
                HorizontalLayout {
                    height: 10%;
                    alignment: center;
                    spacing: 5px;
                    if (root.fs_is_active):
                        MyButton {
                        text: "UNMOUNT";
                        text_color: white;
                        button_color: #FF383C;
                        button_width: 100px;
                        button_height: 40px;
                        is_active: true;
                        on_click => {
                            root.unmount();
                        }
                    }
                    if (!root.fs_is_active):
                        MyButton {
                        text: "MOUNT";
                        text_color: white;
                        button_color: #34C759;
                        button_width: 100px;
                        button_height: 40px;
                        is_active: root.mount_settings.mount_point != "";
                        on_click => {
                            root.mount();
                        }
                    }
                    if root.show_restore_default: 
                    MyButton {
                        text: "RESET";
                        text_color: white;
                        button_color: rgba(0, 128, 255, 0.5);
                        button_width: 100px;
                        button_height: 40px;
                        is_active: !root.fs_is_active;
                        on_click => {
                            root.restore_default();
                        }
                    }
                }
            }
        }
            
        /* --- FOOTER --- */
        Rectangle {
            height: 10%;
            background: rgba(0, 128, 255, 0.5);
            Text {
                text: "Politecnico di Torino";
                font-size: FontPalette.font-small;
                color: white;
                horizontal-alignment: center;
            }
        }
    }
}

/* COMPLETE APPLICATION */
export component App inherits Window {
    background: white;
    min-height: 600px;
    min-width: 800px;
    title: "RemoteFileSystem";
    changed height => {
        FontPalette.scale = round(root.height / 800px);
    }
    callback login(string, string);
    callback retry();
    callback logout();
    callback mount();
    callback unmount();
    in property <ViewState> active_view: ViewState.Welcome;
    in-out property <Status> status: Status.NotLoggedIn;
    in-out property <bool> is_loading: false;
    in-out property <bool> server_unavailable: false;
    in-out property <string> error_message: "";
    in-out property <bool> fs_is_active: false;
    in-out property <bool> show_restore_default: false;
    in property <MountSettings> mount_settings;
    in property <CacheSettings> cache_settings;
    in property <FsSettings> fs_settings;
    in property <LogSettings> log_settings;
    callback change_bool_property(BoolItem);
    callback change_int_property(IntItem);
    callback change_string_property(StringItem);
    callback restore_default();
    WelcomePage {
        visible: active_view == ViewState.Welcome;
        opacity: active_view == ViewState.Welcome ? 1 : 0;
        animate opacity {
            duration: 500ms;
            easing: ease-in-out;
        }
    }

    Home {
        visible: active_view == ViewState.Home;
        opacity: active_view == ViewState.Home ? 1 : 0;
        animate opacity {
            duration: 500ms;
            easing: ease-in-out;
        }
        status: status;
        fs_is_active: fs_is_active;
        show_restore_default: show_restore_default;
        login(u, p) => {
            root.is_loading = true;
            root.login(u, p);
        }
        logout => {
            root.is_loading = true;
            root.logout();
        }
        mount => {
            root.is_loading = true;
            root.mount();
        }
        unmount => {
            root.is_loading = true;
            root.unmount();
        }
        change_bool_property(b) => {
            root.is_loading = true;
            root.change_bool_property(b);
        }
        change_int_property(i) => {
            root.is_loading = true;
            root.change_int_property(i);
        }
        change_string_property(s) => {
            root.is_loading = true;
            root.change_string_property(s);
        }
        restore_default => {
            root.is_loading = true;
            root.restore_default();
        }

        /* Gs card */
        mount_settings: root.mount_settings;
        fs_settings: root.fs_settings;

        /* Cache card */
        cache_settings: root.cache_settings;

        /* Log card */
        log_settings: root.log_settings;
    }

    ServerUnavailable {
        visible: server_unavailable;
        opacity: server_unavailable ? 1 : 0;
        animate opacity {
            duration: 500ms;
            easing: ease-in-out;
        }
        retry => {
            root.is_loading = true;
            root.retry()
        };
    }

    Error {
        visible: error_message != "";
        opacity: error_message != "" ? 1 : 0;
        error: error_message;
        close => {
            error_message = ""
        };
    }

    if (is_loading):
        Loading { }
}

        vertical-alignment: center;
    }
}

export component ServerUnavailable inherits Rectangle {
    callback retry();
    height: 100%;
    width: 100%;
    background: #FFBF00;
    VerticalLayout {
        alignment: center;
        spacing: 40px;
        Text {
            text: "RemoteFileSystem";
            color: black;
            font-size: FontPalette.font-large;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: "Server is not available at the moment!";
            font-size: FontPalette.font-large;
            font-weight: 600;
